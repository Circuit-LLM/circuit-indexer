{
  "name": "circuit-indexer",
  "version": "0.7.0",
  "description": "Circuit Indexer — consumes Geyser event stream, parses Raydium/Orca/PumpSwap pool state and swap transactions, writes real-time OHLCV candles to Redis",
  "main": "indexer.js",
  "type": "commonjs",
  "scripts": {
    "start": "node indexer.js",
    "dev": "node --watch indexer.js",
    "stream": "node indexer.js --consumer=file --file=/tmp/circuit-geyser.jsonl",
    "grpc": "node indexer.js --consumer=grpc"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0"
  },
  "optionalDependencies": {
    "@triton-one/yellowstone-grpc": "^1.4.1",
    "ioredis": "^5.11.0",
    "pg": "^8.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
